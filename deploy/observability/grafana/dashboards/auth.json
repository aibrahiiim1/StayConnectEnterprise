{
  "uid": "stayconnect-auth",
  "title": "StayConnect — Auth",
  "tags": ["stayconnect", "auth"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "tenant_id",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(scd_uptime_seconds, tenant_id)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "OTP issued by channel",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (channel)(rate(scd_otp_issued_total{tenant_id=~\"$tenant_id\"}[5m]))",
        "legendFormat": "{{channel}}"
      }],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 2, "type": "timeseries", "title": "OTP verify outcomes",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (result)(rate(scd_otp_verify_total{tenant_id=~\"$tenant_id\"}[5m]))",
        "legendFormat": "{{result}}"
      }],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 3, "type": "timeseries", "title": "Social login by provider + result",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (provider, result)(rate(scd_social_login_total{tenant_id=~\"$tenant_id\"}[5m]))",
        "legendFormat": "{{provider}}/{{result}}"
      }],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 4, "type": "timeseries", "title": "PMS validate by provider + result",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "sum by (provider, result)(rate(scd_pms_validate_total{tenant_id=~\"$tenant_id\"}[5m]))",
        "legendFormat": "{{provider}}/{{result}}"
      }],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "id": 5, "type": "timeseries", "title": "Social login p95 latency",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (provider, le)(rate(scd_social_login_duration_seconds_bucket{tenant_id=~\"$tenant_id\"}[5m])))",
        "legendFormat": "{{provider}} p95"
      }],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 6, "type": "timeseries", "title": "PMS validate p95 latency",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (provider, le)(rate(scd_pms_validate_duration_seconds_bucket{tenant_id=~\"$tenant_id\"}[5m])))",
        "legendFormat": "{{provider}} p95"
      }],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ]
}
