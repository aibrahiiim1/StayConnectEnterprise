[Unit]
Description=StayConnect Hotel Admin TLS certificate renewal timer (>=daily, jittered)

[Timer]
# After every reboot, then every 6h (>= once daily). Persistent catches runs
# missed while powered off. RandomizedDelaySec spreads a fleet so appliances do
# not all renew at the same instant.
OnBootSec=5min
OnCalendar=*-*-* 00/6:00:00
RandomizedDelaySec=1h
Persistent=true
Unit=stayconnect-hotel-admin-cert-renew.service

[Install]
WantedBy=timers.target
