-- Gate P — runtime role creation TEMPLATE (site DB). Idempotent.
-- Passwords are injected at execution time from secrets generated ON THE APPLIANCE
-- (never committed). Replace the @@..._PW@@ tokens via envsubst/sed at Gate-P execution;
-- this template file itself contains NO secret. Grants are applied separately by
-- deploy/gatep/gatep-grants.sql.
--
-- Every runtime role: LOGIN, NOSUPERUSER, NOCREATEDB, NOCREATEROLE, NOBYPASSRLS, no ownership,
-- connection + timeout guards, and ZERO iam_v2 privileges (never granted here or in gatep-grants.sql).

\set ON_ERROR_STOP on

DO $$ BEGIN CREATE ROLE svc_scd   LOGIN NOSUPERUSER NOCREATEDB NOCREATEROLE NOBYPASSRLS NOREPLICATION; EXCEPTION WHEN duplicate_object THEN NULL; END $$;
DO $$ BEGIN CREATE ROLE svc_edged LOGIN NOSUPERUSER NOCREATEDB NOCREATEROLE NOBYPASSRLS NOREPLICATION; EXCEPTION WHEN duplicate_object THEN NULL; END $$;
DO $$ BEGIN CREATE ROLE svc_acctd LOGIN NOSUPERUSER NOCREATEDB NOCREATEROLE NOBYPASSRLS NOREPLICATION; EXCEPTION WHEN duplicate_object THEN NULL; END $$;
DO $$ BEGIN CREATE ROLE svc_netd  LOGIN NOSUPERUSER NOCREATEDB NOCREATEROLE NOBYPASSRLS NOREPLICATION; EXCEPTION WHEN duplicate_object THEN NULL; END $$;

-- Re-assert attributes (idempotent hardening) + inject rotated passwords.
ALTER ROLE svc_scd   NOSUPERUSER NOCREATEDB NOCREATEROLE NOBYPASSRLS NOREPLICATION CONNECTION LIMIT 20 PASSWORD '@@SVC_SCD_PW@@';
ALTER ROLE svc_edged NOSUPERUSER NOCREATEDB NOCREATEROLE NOBYPASSRLS NOREPLICATION CONNECTION LIMIT 20 PASSWORD '@@SVC_EDGED_PW@@';
ALTER ROLE svc_acctd NOSUPERUSER NOCREATEDB NOCREATEROLE NOBYPASSRLS NOREPLICATION CONNECTION LIMIT 10 PASSWORD '@@SVC_ACCTD_PW@@';
ALTER ROLE svc_netd  NOSUPERUSER NOCREATEDB NOCREATEROLE NOBYPASSRLS NOREPLICATION CONNECTION LIMIT 10 PASSWORD '@@SVC_NETD_PW@@';

-- Statement/lock/idle guards (per role).
ALTER ROLE svc_scd   SET statement_timeout='30s' SET lock_timeout='5s' SET idle_in_transaction_session_timeout='30s';
ALTER ROLE svc_edged SET statement_timeout='60s' SET lock_timeout='5s' SET idle_in_transaction_session_timeout='60s';
ALTER ROLE svc_acctd SET statement_timeout='30s' SET lock_timeout='5s' SET idle_in_transaction_session_timeout='30s';
ALTER ROLE svc_netd  SET statement_timeout='30s' SET lock_timeout='5s' SET idle_in_transaction_session_timeout='30s';
